{
  "name": "dn-otimizacoes-bot",
  "version": "2.0.0",
  "description": "Bot de tickets, planos e atendimento para servidor de otimizações — DN Otimizações.",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start":  "node src/index.js",
    "deploy": "node src/deploy-commands.js",
    "dev":    "node --watch src/index.js",
    "pm2":    "pm2 start src/index.js --name dn-bot --restart-delay=3000 --max-restarts=10"
  },
  "dependencies": {
    "discord.js": "14.14.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "pm2": "^5.3.1"
  }
}
